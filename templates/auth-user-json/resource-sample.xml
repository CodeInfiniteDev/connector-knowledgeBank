            <attribute id="10">
                <ref>ri:accounts</ref>
                <outbound>
                    <name>accounts outbound</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>import com.evolveum.midpoint.xml.ns._public.common.common_3.*
                                import groovy.json.JsonOutput
                                import com.evolveum.midpoint.schema.result.OperationResult

                                def u = focus as UserType
                                def repo = midpoint.repositoryService

                                def entries = []

                                // Iterate all projections (linked accounts)
                                (u.linkRef ?: []).each { linkRef -&gt;
                                def shadowOid = linkRef.oid
                                if (!shadowOid) {
                                return
                                }

                                def shadowObj = repo.getObject(ShadowType.class, shadowOid, null,
                                new OperationResult("loadShadow"))
                                def shadow = shadowObj.asObjectable()

                                // Resolve resource name
                                def resOid = shadow.resourceRef?.oid
                                def resObj = resOid ?
                                repo.getObject(ResourceType.class, resOid, null,
                                new OperationResult("loadResource")) : null
                                def res = resObj?.asObjectable()
                                def resourceName = res?.name?.orig ?: "UNKNOWN"

                                // Decide what you want as resource_account_id
                                // Simplest: use ICF name (icfs:name) if present, else shadow name
                                def accountId = shadow.name?.orig

                                if (accountId) {
                                entries &lt;&lt; [
                                resource  : resourceName,
                                accountId : accountId.toString()
                                ]
                                }
                                }

                                // Return JSON string
                                JsonOutput.toJson(entries)</code>
                        </script>
                    </expression>
                </outbound>
            </attribute>
        </objectType>
    </schemaHandling>
