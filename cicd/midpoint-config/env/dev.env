# ============================================================
# DEV Environment Configuration
# ============================================================
# These values are injected as midPoint constants via MP_SET_ prefix.
# Usage in XML: <const>hrBaseAddress</const>
# ============================================================

# HR System (SCIM Resource)
HR_BASE_ADDRESS=https://192.168.1.10/scim/v2
HR_HOST=192.168.1.10

# LDAP Resource
LDAP_HOST=ldap-dev.example.com
LDAP_PORT=389
LDAP_BASE_CONTEXT=dc=dev,dc=example,dc=com

# Organization
ORG_NAME=Example Inc. (DEV)
