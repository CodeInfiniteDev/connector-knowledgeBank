# ============================================================
# Secrets Properties File (Example)
# ============================================================
# This file is mounted into the container at:
#   /opt/midpoint/var/secrets/secrets.properties
#
# Referenced by the "properties-provider" secrets provider
# defined in 010-system-configuration.xml.
#
# Usage in resource XML (ProtectedStringType fields ONLY):
#   <t:externalData>
#       <t:provider>properties-provider</t:provider>
#       <t:key>hr.password</t:key>
#   </t:externalData>
#
# DO NOT commit real secrets to Git!
# Use GitLab CI/CD variables or external secret management.
# ============================================================

hr.password=changeme
hr.username=admin
ldap.bindPassword=changeme
db.password=changeme
